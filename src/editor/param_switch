use nih_plug::prelude::{Enum, Param};
use nih_plug_vizia::vizia::prelude::*;
use nih_plug_vizia::widgets::param_base::ParamWidgetBase;

use crate::Channel;

#[derive(Debug)]
pub enum ParamEvent {
    BeginSetParam,
    SetParam(Channel),
    EndSetParam,
}

#[derive(Lens)]
pub struct ParamSwitch {
    param_base: ParamWidgetBase,
}

impl ParamSwitch {
    pub fn new<L, Params, P, FMap>(
        cx: &mut Context,
        params: L,
        options: L,
        params_to_param: FMap,
    ) -> Handle<Self>
    where
        L: Lens<Target = Params> + Clone + Copy,
        Params: 'static,
        P: Param + 'static,
        FMap: Fn(&Params) -> &P + Copy + 'static,
    {
        Self {
            param_base: ParamWidgetBase::new(cx, params.clone(), params_to_param),
        }
        .build(
            cx,
            ParamWidgetBase::build_view(params, params_to_param, move |cx, param_data| {
                HStack::new(cx, |cx| {
                    for option in options.iter() {
                        RadioButton::new(cx, params).on_select(|cx| {
                            cx.emit(ParamEvent::BeginSetParam);
                            cx.emit(ParamEvent::SetParam(*option));
                            cx.emit(ParamEvent::EndSetParam);
                        });
                        Label::new(cx, stringify!(option));
                        // Button::new(
                        //     cx,
                        //     |cx| cx.emit(ParamEvent::SetParam(*option)),
                        //     |cx| Label::new(cx, stringify!(option)),
                        // )
                        // .class("param_switch_item");
                    }

                    Button::new(cx, |_| {}, |cx| Label::new(cx, "Left")).class("param_switch_item");
                })
                .class("param_switch");

                Label::new(
                    cx,
                    params.map(move |params| params_to_param(params).name().to_owned()),
                )
                .space(Stretch(1.0))
                .top(Stretch(0.));
            }),
        )
    }
}

impl View for ParamSwitch {
    fn event(&mut self, cx: &mut EventContext, event: &mut Event) {
        event.map(|param_change_event, _| match param_change_event {
            ParamEvent::BeginSetParam => {
                self.param_base.begin_set_parameter(cx);
            }
            ParamEvent::SetParam(val) => {
                self.param_base.set_normalized_value(cx, *val as i32 as f32);
            }
            ParamEvent::EndSetParam => {
                self.param_base.end_set_parameter(cx);
            }
        });
    }
}
