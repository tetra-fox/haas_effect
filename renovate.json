{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:base", ":semanticCommits", "schedule:weekly"],
    "automerge": true,
    "automergeType": "branch",
    "packageRules": [
      {
        "matchUpdateTypes": ["minor", "patch"],
        "groupName": "cargo",
        "matchManagers": ["cargo"]
      }
    ]
  }